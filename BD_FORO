USE [master]
GO

IF DB_ID('ForoWeb') IS NULL
BEGIN
    CREATE DATABASE [ForoWeb];
END
GO

ALTER DATABASE [ForoWeb] SET COMPATIBILITY_LEVEL = 150
GO

USE [ForoWeb]
GO

-- Limpiar tablas en orden correcto (respetando FK)
IF OBJECT_ID('dbo.Submissions',    'U') IS NOT NULL DROP TABLE dbo.Submissions;
IF OBJECT_ID('dbo.Replies',        'U') IS NOT NULL DROP TABLE dbo.Replies;
IF OBJECT_ID('dbo.Threads',        'U') IS NOT NULL DROP TABLE dbo.Threads;
IF OBJECT_ID('dbo.Assignments',    'U') IS NOT NULL DROP TABLE dbo.Assignments;
IF OBJECT_ID('dbo.ClassStudents',  'U') IS NOT NULL DROP TABLE dbo.ClassStudents;
IF OBJECT_ID('dbo.Clases',         'U') IS NOT NULL DROP TABLE dbo.Clases;
IF OBJECT_ID('dbo.Courses',        'U') IS NOT NULL DROP TABLE dbo.Courses;
IF OBJECT_ID('dbo.Categories',     'U') IS NOT NULL DROP TABLE dbo.Categories;
IF OBJECT_ID('dbo.Users',          'U') IS NOT NULL DROP TABLE dbo.Users;
GO

CREATE TABLE [dbo].[Users](
    [UserId]       INT IDENTITY(1,1) NOT NULL,
    [FullName]     NVARCHAR(100) NOT NULL,
    [Email]        NVARCHAR(100) NOT NULL,
    [Role]         NVARCHAR(20)  NOT NULL,
    [IsActive]     BIT NOT NULL CONSTRAINT DF_Users_IsActive DEFAULT ((1)),
    [PasswordHash] NVARCHAR(255) NOT NULL,
    [PhotoUrl]     NVARCHAR(255) NULL,
    CONSTRAINT PK_Users PRIMARY KEY CLUSTERED ([UserId] ASC),
    CONSTRAINT UQ_Users_Email UNIQUE ([Email]),
    CONSTRAINT CK_Users_Role CHECK ([Role] IN ('Profesor', 'Estudiante', 'Administrador'))
);
GO

CREATE TABLE [dbo].[Categories](
    [CategoryId]  INT IDENTITY(1,1) NOT NULL,
    [Name]        NVARCHAR(100) NOT NULL,
    [Description] NVARCHAR(300) NULL,
    CONSTRAINT PK_Categories PRIMARY KEY CLUSTERED ([CategoryId] ASC),
    CONSTRAINT UQ_Categories_Name UNIQUE ([Name])
);
GO

CREATE TABLE [dbo].[Courses](
    [CourseId]    INT IDENTITY(1,1) NOT NULL,
    [Name]        NVARCHAR(150) NOT NULL,
    [Description] NVARCHAR(500) NULL,
    [CreatedAt]   DATETIME NOT NULL CONSTRAINT DF_Courses_CreatedAt DEFAULT (GETDATE()),
    CONSTRAINT PK_Courses PRIMARY KEY CLUSTERED ([CourseId] ASC)
);
GO

CREATE TABLE [dbo].[Clases](
    [ClaseId]     INT IDENTITY(1,1) NOT NULL,
    [CourseId]    INT NOT NULL,
    [ProfessorId] INT NOT NULL,
    [Name]        NVARCHAR(150) NOT NULL,
    [CreatedAt]   DATETIME NOT NULL CONSTRAINT DF_Clases_CreatedAt DEFAULT (GETDATE()),
    CONSTRAINT PK_Clases PRIMARY KEY CLUSTERED ([ClaseId] ASC)
);
GO

CREATE TABLE [dbo].[ClassStudents](
    [ClaseId]   INT NOT NULL,
    [StudentId] INT NOT NULL,
    CONSTRAINT PK_ClassStudents PRIMARY KEY ([ClaseId], [StudentId])
);
GO

CREATE TABLE [dbo].[Threads](
    [ThreadId]   INT IDENTITY(1,1) NOT NULL,
    [CategoryId] INT NOT NULL,
    [UserId]     INT NOT NULL,
    [Title]      NVARCHAR(150) NOT NULL,
    [Message]    NVARCHAR(MAX) NOT NULL,
    [CreatedAt]  DATETIME NOT NULL CONSTRAINT DF_Threads_CreatedAt DEFAULT (GETDATE()),
    CONSTRAINT PK_Threads PRIMARY KEY CLUSTERED ([ThreadId] ASC)
);
GO

CREATE TABLE [dbo].[Replies](
    [ReplyId]   INT IDENTITY(1,1) NOT NULL,
    [ThreadId]  INT NOT NULL,
    [UserId]    INT NOT NULL,
    [Message]   NVARCHAR(MAX) NOT NULL,
    [CreatedAt] DATETIME NOT NULL CONSTRAINT DF_Replies_CreatedAt DEFAULT (GETDATE()),
    CONSTRAINT PK_Replies PRIMARY KEY CLUSTERED ([ReplyId] ASC)
);
GO

CREATE TABLE [dbo].[Assignments](
    [AssignmentId] INT IDENTITY(1,1) NOT NULL,
    [ProfessorId]  INT NOT NULL,
    [ClassId]      INT NOT NULL,
    [Title]        NVARCHAR(150) NOT NULL,
    [Description]  NVARCHAR(MAX) NOT NULL,
    [DueDate]      DATETIME NOT NULL,
    [CreatedAt]    DATETIME NOT NULL CONSTRAINT DF_Assignments_CreatedAt DEFAULT (GETDATE()),
    CONSTRAINT PK_Assignments PRIMARY KEY CLUSTERED ([AssignmentId] ASC)
);
GO

CREATE TABLE [dbo].[Submissions](
    [SubmissionId] INT IDENTITY(1,1) NOT NULL,
    [AssignmentId] INT NOT NULL,
    [StudentId]    INT NOT NULL,
    [FileUrl]      NVARCHAR(500) NULL,
    [Comment]      NVARCHAR(MAX) NULL,
    [SubmittedAt]  DATETIME NOT NULL CONSTRAINT DF_Submissions_SubmittedAt DEFAULT (GETDATE()),
    CONSTRAINT PK_Submissions PRIMARY KEY CLUSTERED ([SubmissionId] ASC)
);
GO

-- Foreign Keys
ALTER TABLE [dbo].[Clases]        ADD CONSTRAINT FK_Clases_Courses    FOREIGN KEY ([CourseId])    REFERENCES [dbo].[Courses]  ([CourseId]);
ALTER TABLE [dbo].[Clases]        ADD CONSTRAINT FK_Clases_Users      FOREIGN KEY ([ProfessorId]) REFERENCES [dbo].[Users]    ([UserId]);
ALTER TABLE [dbo].[ClassStudents] ADD CONSTRAINT FK_CS_Clases         FOREIGN KEY ([ClaseId])     REFERENCES [dbo].[Clases]   ([ClaseId]);
ALTER TABLE [dbo].[ClassStudents] ADD CONSTRAINT FK_CS_Users          FOREIGN KEY ([StudentId])   REFERENCES [dbo].[Users]    ([UserId]);
ALTER TABLE [dbo].[Threads]       ADD CONSTRAINT FK_Threads_Categories FOREIGN KEY ([CategoryId]) REFERENCES [dbo].[Categories] ([CategoryId]);
ALTER TABLE [dbo].[Threads]       ADD CONSTRAINT FK_Threads_Users     FOREIGN KEY ([UserId])      REFERENCES [dbo].[Users]    ([UserId]);
ALTER TABLE [dbo].[Replies]       ADD CONSTRAINT FK_Replies_Threads   FOREIGN KEY ([ThreadId])    REFERENCES [dbo].[Threads]  ([ThreadId]);
ALTER TABLE [dbo].[Replies]       ADD CONSTRAINT FK_Replies_Users     FOREIGN KEY ([UserId])      REFERENCES [dbo].[Users]    ([UserId]);
ALTER TABLE [dbo].[Assignments]   ADD CONSTRAINT FK_Assignments_Clases  FOREIGN KEY ([ClassId])   REFERENCES [dbo].[Clases]   ([ClaseId]);
ALTER TABLE [dbo].[Assignments]   ADD CONSTRAINT FK_Assignments_Users   FOREIGN KEY ([ProfessorId]) REFERENCES [dbo].[Users] ([UserId]);
ALTER TABLE [dbo].[Submissions]   ADD CONSTRAINT FK_Submissions_Assignments FOREIGN KEY ([AssignmentId]) REFERENCES [dbo].[Assignments] ([AssignmentId]);
ALTER TABLE [dbo].[Submissions]   ADD CONSTRAINT FK_Submissions_Users  FOREIGN KEY ([StudentId])  REFERENCES [dbo].[Users]    ([UserId]);
GO

