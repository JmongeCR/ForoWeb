USE [master]
GO

IF DB_ID('ForoU') IS NULL
BEGIN
    CREATE DATABASE [ForoU];
END
GO

ALTER DATABASE [ForoU] SET COMPATIBILITY_LEVEL = 150
GO

USE [ForoU]
GO

IF OBJECT_ID('dbo.Replies', 'U') IS NOT NULL DROP TABLE dbo.Replies;
IF OBJECT_ID('dbo.Threads', 'U') IS NOT NULL DROP TABLE dbo.Threads;
IF OBJECT_ID('dbo.Assignments', 'U') IS NOT NULL DROP TABLE dbo.Assignments;
IF OBJECT_ID('dbo.Categories', 'U') IS NOT NULL DROP TABLE dbo.Categories;
IF OBJECT_ID('dbo.Users', 'U') IS NOT NULL DROP TABLE dbo.Users;
GO

CREATE TABLE [dbo].[Users](
    [UserId] INT IDENTITY(1,1) NOT NULL,
    [FullName] NVARCHAR(100) NOT NULL,
    [Email] NVARCHAR(100) NOT NULL,
    [Role] NVARCHAR(20) NOT NULL,
    [IsActive] BIT NOT NULL CONSTRAINT DF_Users_IsActive DEFAULT ((1)),
    [PasswordHash] NVARCHAR(255) NOT NULL,
    [PhotoUrl] NVARCHAR(255) NULL,
    CONSTRAINT PK_Users PRIMARY KEY CLUSTERED ([UserId] ASC),
    CONSTRAINT UQ_Users_Email UNIQUE ([Email]),
    CONSTRAINT CK_Users_Role CHECK ([Role] IN ('Profesor', 'Estudiante', 'Administrador'))
);
GO

CREATE TABLE [dbo].[Categories](
    [CategoryId] INT IDENTITY(1,1) NOT NULL,
    [Name] NVARCHAR(100) NOT NULL,
    [Description] NVARCHAR(300) NULL,
    CONSTRAINT PK_Categories PRIMARY KEY CLUSTERED ([CategoryId] ASC),
    CONSTRAINT UQ_Categories_Name UNIQUE ([Name])
);
GO

CREATE TABLE [dbo].[Threads](
    [ThreadId] INT IDENTITY(1,1) NOT NULL,
    [CategoryId] INT NOT NULL,
    [UserId] INT NOT NULL,
    [Title] NVARCHAR(150) NOT NULL,
    [Message] NVARCHAR(MAX) NOT NULL,
    [CreatedAt] DATETIME NOT NULL CONSTRAINT DF_Threads_CreatedAt DEFAULT (GETDATE()),
    CONSTRAINT PK_Threads PRIMARY KEY CLUSTERED ([ThreadId] ASC)
);
GO

CREATE TABLE [dbo].[Replies](
    [ReplyId] INT IDENTITY(1,1) NOT NULL,
    [ThreadId] INT NOT NULL,
    [UserId] INT NOT NULL,
    [Message] NVARCHAR(MAX) NOT NULL,
    [CreatedAt] DATETIME NOT NULL CONSTRAINT DF_Replies_CreatedAt DEFAULT (GETDATE()),
    CONSTRAINT PK_Replies PRIMARY KEY CLUSTERED ([ReplyId] ASC)
);
GO

CREATE TABLE [dbo].[Assignments](
    [AssignmentId] INT IDENTITY(1,1) NOT NULL,
    [CategoryId] INT NOT NULL,
    [TeacherId] INT NOT NULL,
    [Title] NVARCHAR(150) NOT NULL,
    [Description] NVARCHAR(MAX) NOT NULL,
    [DueDate] DATE NOT NULL,
    CONSTRAINT PK_Assignments PRIMARY KEY CLUSTERED ([AssignmentId] ASC)
);
GO

ALTER TABLE [dbo].[Threads] WITH CHECK ADD CONSTRAINT FK_Threads_Categories
FOREIGN KEY([CategoryId]) REFERENCES [dbo].[Categories] ([CategoryId]);
GO

ALTER TABLE [dbo].[Threads] WITH CHECK ADD CONSTRAINT FK_Threads_Users
FOREIGN KEY([UserId]) REFERENCES [dbo].[Users] ([UserId]);
GO

ALTER TABLE [dbo].[Replies] WITH CHECK ADD CONSTRAINT FK_Replies_Threads
FOREIGN KEY([ThreadId]) REFERENCES [dbo].[Threads] ([ThreadId]);
GO

ALTER TABLE [dbo].[Replies] WITH CHECK ADD CONSTRAINT FK_Replies_Users
FOREIGN KEY([UserId]) REFERENCES [dbo].[Users] ([UserId]);
GO

ALTER TABLE [dbo].[Assignments] WITH CHECK ADD CONSTRAINT FK_Assignments_Categories
FOREIGN KEY([CategoryId]) REFERENCES [dbo].[Categories] ([CategoryId]);
GO

ALTER TABLE [dbo].[Assignments] WITH CHECK ADD CONSTRAINT FK_Assignments_Users
FOREIGN KEY([TeacherId]) REFERENCES [dbo].[Users] ([UserId]);
GO

