@model AP.MVC.Models.ClaseDetailsVM

@{
    ViewBag.Title = Model.Clase.Name + " – Estudiantes";
}

<style>
    .forou-detail-wrap {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .forou-detail-card {
        background: #fff;
        border: 1px solid #e2e8f4;
        border-radius: 16px;
        padding: 26px;
        box-shadow: 0 2px 8px rgba(26,53,112,0.06);
    }

    .forou-section-title {
        font-size: 18px;
        font-weight: 800;
        color: #1a3570;
        margin: 0 0 16px 0;
    }

    .forou-info-row {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 6px;
    }

    .forou-info-item {
        color: #5a6a85;
        font-size: 14px;
    }

        .forou-info-item strong {
            color: #1a3570;
        }

    .forou-badge-course {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        background: #dbeafe;
        border: 1px solid #bfdbfe;
        color: #1e40af;
    }

    .forou-students-table {
        width: 100%;
        border-collapse: collapse;
    }

        .forou-students-table th {
            text-align: left;
            padding: 10px 14px;
            color: #1a3570;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            border-bottom: 1px solid #e2e8f4;
        }

        .forou-students-table td {
            padding: 12px 14px;
            color: #4a5e7a;
            font-size: 14px;
            border-bottom: 1px solid #f0f4fa;
        }

        .forou-students-table tr:last-child td {
            border-bottom: none;
        }

        .forou-students-table tr:hover td {
            background: #f7f9fd;
        }

    .forou-remove-btn {
        display: inline-block;
        background: #fee2e2;
        border: 1px solid #fecaca;
        color: #991b1b;
        font-size: 12px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 8px;
        cursor: pointer;
    }

        .forou-remove-btn:hover {
            background: #fecaca;
        }

    .forou-add-row {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        margin-top: 6px;
    }

    .forou-select-dark {
        border-radius: 10px;
        border: 1.5px solid #d0d9ee;
        background: #f7f9fd;
        color: #1e2d4a;
        padding: 9px 14px;
        font-size: 14px;
        font-family: inherit;
        min-width: 220px;
    }

        .forou-select-dark:focus {
            outline: none;
            border-color: #1e4db7;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(30,77,183,0.1);
        }

    .forou-btn-add {
        display: inline-block;
        background: linear-gradient(90deg, #1a3570 0%, #1e4db7 100%);
        color: #fff;
        border: none;
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
        font-size: 14px;
        box-shadow: 0 4px 12px rgba(30,77,183,0.22);
    }

        .forou-btn-add:hover { opacity: 0.92; }

    .forou-empty {
        color: #6b7f9e;
        font-size: 14px;
    }

    .forou-success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
        border-radius: 12px;
        padding: 14px 18px;
        margin-bottom: 18px;
    }

    .forou-btn-secondary {
        display: inline-block;
        background: #f0f4ff;
        color: #1e4db7;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 700;
        border: 1.5px solid #bfdbfe;
        font-size: 14px;
    }

        .forou-btn-secondary:hover {
            background: #dbeafe;
            color: #1e3a8a;
            text-decoration: none;
        }
</style>

<div class="forou-breadcrumb">
    <a href="@Url.Action("Index", "Clase")">Clases</a>
    <span class="forou-breadcrumb-sep">›</span>
    <span class="forou-breadcrumb-current">@Model.Clase.Name</span>
</div>

@if (TempData["Success"] != null)
{
    <div class="forou-success">@TempData["Success"]</div>
}

<div class="forou-detail-wrap">

    <div class="forou-detail-card">
        <h2 class="forou-section-title">@Model.Clase.Name</h2>
        <div class="forou-info-row">
            <div class="forou-info-item">
                Curso: <span class="forou-badge-course">@Model.Clase.CourseName</span>
            </div>
            <div class="forou-info-item">
                Profesor: <strong>@Model.Clase.ProfessorName</strong>
            </div>
        </div>
    </div>

    <div class="forou-detail-card">
        <h2 class="forou-section-title">Estudiantes matriculados (@Model.Students.Count)</h2>

        @if (Model.Students.Count > 0)
        {
            <table class="forou-students-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Students)
                    {
                        <tr>
                            <td style="color:#1e293b; font-weight:600;">@s.FullName</td>
                            <td>@s.Email</td>
                            <td>
                                @using (Html.BeginForm("RemoveStudent", "Clase", FormMethod.Post, new { style = "display:inline;" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="claseId" value="@Model.Clase.ClaseId" />
                                    <input type="hidden" name="studentId" value="@s.UserId" />
                                    <button type="submit" class="forou-remove-btn">Quitar</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="forou-empty">No hay estudiantes matriculados a&uacute;n.</div>
        }
    </div>

    @if (Model.AvailableStudents.Count > 0)
    {
        <div class="forou-detail-card">
            <h2 class="forou-section-title">Agregar estudiante</h2>
            @using (Html.BeginForm("AddStudent", "Clase", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="claseId" value="@Model.Clase.ClaseId" />
                <div class="forou-add-row">
                    <select name="studentId" class="forou-select-dark">
                        <option value="0">-- Seleccionar estudiante --</option>
                        @foreach (var s in Model.AvailableStudents)
                        {
                            <option value="@s.UserId">@s.FullName (@s.Email)</option>
                        }
                    </select>
                    <button type="submit" class="forou-btn-add">Agregar</button>
                </div>
            }
        </div>
    }

    <div>
        <a class="forou-btn-secondary" href="@Url.Action("Index", "Clase")">Volver a Clases</a>
    </div>

</div>
