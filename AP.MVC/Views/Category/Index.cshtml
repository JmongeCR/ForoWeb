@model IEnumerable<AP.Models.Category>

@{
    ViewBag.Title = "Foro";
}

<style>
    .foro-hero {
        background: linear-gradient(120deg, #6366f1 0%, #818cf8 100%);
        border-radius: 16px;
        padding: 36px 40px;
        color: #fff;
        margin-bottom: 28px;
    }

    .foro-hero-label {
        font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
        text-transform: uppercase; opacity: 0.75; margin-bottom: 8px;
    }

    .foro-hero-title {
        font-size: 28px; font-weight: 800; margin-bottom: 6px; line-height: 1.2;
    }

    .foro-hero-sub {
        font-size: 15px; opacity: 0.8; max-width: 500px;
    }

    .foro-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 18px;
    }

    .foro-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(99,102,241,0.06);
        transition: box-shadow 0.18s, transform 0.18s, border-color 0.18s;
        display: flex;
        flex-direction: column;
    }

    .foro-card:hover {
        box-shadow: 0 8px 24px rgba(99,102,241,0.12);
        transform: translateY(-3px);
        border-color: #a5b4fc;
    }

    .foro-card-icon {
        width: 46px; height: 46px;
        border-radius: 12px;
        background: #ede9fe; border: 1px solid #ddd6fe;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
        margin-bottom: 16px;
        flex-shrink: 0;
    }

    .foro-card-name {
        font-size: 17px; font-weight: 800;
        color: #1e293b; margin-bottom: 8px;
    }

    .foro-card-desc {
        color: #64748b; font-size: 14px;
        line-height: 1.55; margin-bottom: 20px; flex: 1;
    }

    .foro-card-btn {
        display: inline-flex; align-items: center; gap: 6px;
        background: #f5f3ff; color: #6366f1; border: 1px solid #ddd6fe;
        text-decoration: none;
        padding: 9px 16px;
        border-radius: 9px; font-weight: 700; font-size: 13px;
        transition: all 0.15s;
        align-self: flex-start;
    }

    .foro-card-btn:hover { background: #ede9fe; border-color: #c4b5fd; color: #6366f1; text-decoration: none; }

    .foro-empty {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 16px;
        padding: 60px; text-align: center;
        box-shadow: 0 2px 8px rgba(99,102,241,0.05);
    }

    @@media (max-width: 700px) {
        .foro-grid { grid-template-columns: 1fr; }
        .foro-hero { padding: 28px 24px; }
    }
</style>

<div class="foro-hero">
    <div class="foro-hero-label">Foro acad&eacute;mico</div>
    <div class="foro-hero-title">Canales de discusi&oacute;n</div>
    <div class="foro-hero-sub">Seleccion&aacute; una materia para ver y participar en las consultas del canal.</div>
</div>

@if (!Model.Any())
{
    <div class="foro-empty">
        <div style="font-size:44px; margin-bottom:14px;">&#x1F4DA;</div>
        <div style="font-size:18px; font-weight:800; color:#1e293b; margin-bottom:8px;">Sin categor&iacute;as disponibles</div>
        <div style="color:#64748b;">El administrador a&uacute;n no ha creado canales de discusi&oacute;n.</div>
    </div>
}
else
{
    <div class="foro-grid">
        @foreach (var c in Model)
        {
            <div class="foro-card">
                <div class="foro-card-icon">&#x1F4AC;</div>
                <div class="foro-card-name">@c.Name</div>
                <div class="foro-card-desc">@c.Description</div>
                <a class="foro-card-btn"
                   href="@Url.Action("Index", "Thread", new { categoryId = c.CategoryId })">
                    Abrir canal &rarr;
                </a>
            </div>
        }
    </div>
}
