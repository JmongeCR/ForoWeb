@model AP.MVC.Models.ProfileVM

@{
    ViewBag.Title = "Mi perfil";
}

<style>
    .forou-profile-wrap { max-width: 860px; margin: 0 auto; }

    .forou-profile-card {
        background: #fff; border: 1px solid #e2e8f0;
        border-radius: 20px; padding: 32px;
        box-shadow: 0 2px 8px rgba(99,102,241,0.07);
        display: flex; gap: 32px; align-items: flex-start;
    }

    .forou-profile-left { display: flex; flex-direction: column; align-items: center; gap: 12px; flex-shrink: 0; }

    .forou-profile-avatar {
        width: 120px; height: 120px; border-radius: 50%;
        object-fit: cover; border: 3px solid #e2e8f0;
    }

    .forou-profile-avatar-init {
        width: 120px; height: 120px; border-radius: 50%;
        background: #6366f1; color: #fff;
        font-size: 48px; font-weight: 800;
        display: flex; align-items: center; justify-content: center;
        border: 3px solid #ddd6fe;
    }

    .forou-upload-btn {
        display: inline-block; padding: 6px 14px;
        border-radius: 8px; border: 1.5px solid #c4b5fd;
        background: #f5f3ff; color: #6366f1;
        font-size: 12px; font-weight: 700; cursor: pointer;
        transition: all 0.15s; white-space: nowrap;
    }
    .forou-upload-btn:hover { background: #ede9fe; }

    #photoInput { display: none; }

    .forou-profile-title { font-size: 26px; font-weight: 800; color: #1e293b; margin-bottom: 4px; }
    .forou-profile-sub   { color: #64748b; margin-bottom: 22px; font-size: 15px; }

    .forou-profile-grid {
        display: grid; grid-template-columns: 140px 1fr;
        gap: 12px 20px;
    }

    .forou-profile-label { color: #6366f1; font-weight: 700; font-size: 14px; }
    .forou-profile-value { color: #1e293b; font-size: 14px; }

    /* Sección clases */
    .forou-classes-card {
        background: #fff; border: 1px solid #e2e8f0;
        border-radius: 20px; padding: 28px 32px;
        box-shadow: 0 2px 8px rgba(99,102,241,0.07);
        margin-top: 20px;
    }

    .forou-classes-title {
        font-size: 18px; font-weight: 800; color: #1e293b;
        margin: 0 0 18px 0; display: flex; align-items: center; gap: 10px;
    }

    .forou-classes-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 14px;
    }

    .forou-class-item {
        background: #f8fafc; border: 1px solid #e2e8f0;
        border-radius: 12px; padding: 16px 18px;
        display: flex; flex-direction: column; gap: 6px;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .forou-class-item:hover {
        border-color: #a5b4fc;
        box-shadow: 0 4px 12px rgba(99,102,241,0.1);
    }

    .forou-class-name { font-size: 14px; font-weight: 700; color: #1e293b; }
    .forou-class-course {
        display: inline-block; font-size: 11px; font-weight: 700;
        background: #ede9fe; color: #6366f1;
        padding: 2px 9px; border-radius: 999px;
        align-self: flex-start;
    }
    .forou-class-prof { font-size: 12px; color: #94a3b8; }

    .forou-classes-empty {
        color: #94a3b8; font-size: 14px; text-align: center; padding: 24px 0;
    }

    @@media (max-width: 640px) {
        .forou-profile-card { flex-direction: column; align-items: center; }
        .forou-profile-grid { grid-template-columns: 1fr; }
        .forou-classes-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="forou-profile-wrap">
    <div class="forou-profile-card">

        <div class="forou-profile-left">
            @{
                bool hasPhoto = !string.IsNullOrWhiteSpace(Model.PhotoUrl)
                    && !Model.PhotoUrl.Contains("default-avatar");
            }
            @if (hasPhoto)
            {
                <img class="forou-profile-avatar" id="avatarImg"
                     src="@Url.Content(Model.PhotoUrl)" alt="@Model.FullName" />
            }
            else
            {
                <div class="forou-profile-avatar-init" id="avatarInit">
                    @(Model.FullName.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "U")
                </div>
            }

            @using (Html.BeginForm("UpdatePhoto", "Profiled", FormMethod.Post,
                new { enctype = "multipart/form-data", id = "photoForm" }))
            {
                @Html.AntiForgeryToken()
                <label class="forou-upload-btn" for="photoInput">Cambiar foto</label>
                <input type="file" name="photo" id="photoInput" accept="image/*" />
            }
        </div>

        <div style="flex:1;">
            <div class="forou-profile-title">@Model.FullName</div>
            <div class="forou-profile-sub">Informaci&oacute;n de tu cuenta en ForoU</div>

            <div class="forou-profile-grid">
                <div class="forou-profile-label">Correo</div>
                <div class="forou-profile-value">@Model.Email</div>

                <div class="forou-profile-label">Rol</div>
                <div class="forou-profile-value">@Model.Role</div>
            </div>
        </div>

    </div>
</div>

@* Sección de clases (Estudiante / Profesor) *@
@if (Model.Role != "Administrador")
{
    <div class="forou-profile-wrap">
        <div class="forou-classes-card">
            <h2 class="forou-classes-title">
                @if (Model.Role == "Estudiante")
                {
                    <span>&#x1F393;</span>
                    <span>Mis clases inscritas</span>
                }
                else
                {
                    <span>&#x1F4DA;</span>
                    <span>Mis clases asignadas</span>
                }
            </h2>

            @if (Model.Clases != null && Model.Clases.Count > 0)
            {
                <div class="forou-classes-grid">
                    @foreach (var c in Model.Clases)
                    {
                        <div class="forou-class-item">
                            <div class="forou-class-name">@c.Name</div>
                            <span class="forou-class-course">@c.CourseName</span>
                            @if (Model.Role == "Estudiante")
                            {
                                <div class="forou-class-prof">Profesor: @c.ProfessorName</div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="forou-classes-empty">
                    @if (Model.Role == "Estudiante")
                    {
                        <text>No est&aacute;s inscrito en ninguna clase todav&iacute;a.</text>
                    }
                    else
                    {
                        <text>No ten&eacute;s clases asignadas todav&iacute;a.</text>
                    }
                </div>
            }
        </div>
    </div>
}

@section scripts {
<script>
    document.getElementById('photoInput').addEventListener('change', function () {
        if (this.files && this.files[0]) {
            document.getElementById('photoForm').submit();
        }
    });
</script>
}
