@model AP.MVC.Models.ProfileVM

@{
    ViewBag.Title = "Mi perfil";
}

<style>
    .forou-profile-wrap {
        max-width: 980px;
        margin: 0 auto;
    }

    .forou-profile-card {
        background: #111328;
        border: 1px solid rgba(123, 137, 255, 0.14);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 18px 40px rgba(0,0,0,0.18);
        display: flex;
        gap: 30px;
        align-items: center;
    }

    .forou-profile-avatar {
        width: 140px;
        height: 140px;
        border-radius: 22px;
        object-fit: cover;
        border: 2px solid rgba(123, 137, 255, 0.30);
        box-shadow: 0 0 20px rgba(91, 105, 255, 0.18);
        background: #0c1022;
    }

    .forou-profile-title {
        font-size: 34px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 8px 0;
    }

    .forou-profile-sub {
        color: #c7d0f1;
        margin-bottom: 24px;
        font-size: 17px;
    }

    .forou-profile-grid {
        display: grid;
        grid-template-columns: 170px 1fr;
        gap: 14px 24px;
    }

    .forou-profile-label {
        color: #9eabd6;
        font-weight: 700;
        font-size: 18px;
    }

    .forou-profile-value {
        color: #eef1ff;
        font-size: 18px;
    }

    @@media (max-width: 768px) {
        .forou-profile-card {
            flex-direction: column;
            align-items: flex-start;
        }

        .forou-profile-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="forou-profile-wrap">
    <div class="forou-profile-card">
        <img class="forou-profile-avatar"
             src="@Url.Content(string.IsNullOrWhiteSpace(Model.PhotoUrl) ? "~/Content/img/default-avatar.png" : Model.PhotoUrl)"
             alt="Foto de perfil" />

        <div>
            <h1 class="forou-profile-title">@Model.FullName</h1>
            <div class="forou-profile-sub">Información de tu cuenta en ForoU</div>

            <div class="forou-profile-grid">
                <div class="forou-profile-label">Correo</div>
                <div class="forou-profile-value">@Model.Email</div>

                <div class="forou-profile-label">Rol</div>
                <div class="forou-profile-value">@Model.Role</div>

                <div class="forou-profile-label">ID usuario</div>
                <div class="forou-profile-value">@Model.UserId</div>
            </div>
        </div>
    </div>
</div>