@{
    ViewBag.Title = "Inicio";
    var userRole = Session["UserRole"] != null ? Session["UserRole"].ToString() : "";
    var userName = Session["UserName"] != null ? Session["UserName"].ToString() : "Usuario";
}

<style>
    .home-hero {
        background: linear-gradient(120deg, #6366f1 0%, #818cf8 100%);
        border-radius: 16px;
        padding: 40px 44px;
        margin-bottom: 24px;
        color: #fff;
        display: flex; align-items: center; justify-content: space-between; gap: 24px;
    }

    .home-hero-left { flex: 1; }

    .home-hero-badge {
        display: inline-block; font-size: 11px; font-weight: 700;
        background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.3);
        padding: 3px 10px; border-radius: 4px; margin-bottom: 14px;
        letter-spacing: 0.05em; text-transform: uppercase;
    }

    .home-hero-title {
        font-size: 32px; font-weight: 800; margin: 0 0 10px 0; line-height: 1.2;
    }

    .home-hero-sub {
        font-size: 15px; opacity: 0.85; line-height: 1.65; max-width: 480px; margin-bottom: 28px;
    }

    .home-hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

    .home-hero-btn {
        display: inline-flex; align-items: center; gap: 7px;
        background: #fff; color: #6366f1; text-decoration: none;
        padding: 10px 22px; border-radius: 8px;
        font-weight: 800; font-size: 14px;
        transition: opacity 0.15s, transform 0.15s;
    }
    .home-hero-btn:hover { opacity: 0.92; color: #6366f1; text-decoration: none; transform: translateY(-1px); }

    .home-hero-btn-outline {
        display: inline-flex; align-items: center; gap: 7px;
        background: transparent; border: 1.5px solid rgba(255,255,255,0.5);
        color: #fff; text-decoration: none;
        padding: 10px 22px; border-radius: 8px;
        font-weight: 700; font-size: 14px;
        transition: all 0.15s;
    }
    .home-hero-btn-outline:hover { background: rgba(255,255,255,0.15); color: #fff; text-decoration: none; }

    .home-hero-right {
        flex-shrink: 0;
        background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25);
        border-radius: 14px; padding: 24px 28px; min-width: 200px; text-align: center;
    }

    .home-hero-avatar {
        width: 56px; height: 56px; border-radius: 50%;
        background: rgba(255,255,255,0.25);
        color: #fff; font-weight: 800; font-size: 22px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 14px;
    }

    .home-hero-uname { font-size: 16px; font-weight: 700; }
    .home-hero-role {
        display: inline-block; margin-top: 6px; font-size: 12px;
        background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3);
        padding: 2px 10px; border-radius: 999px; font-weight: 600;
    }

    .home-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }

    .home-card {
        background: #fff; border: 1px solid #e2e8f0;
        border-radius: 14px; overflow: hidden;
        box-shadow: 0 2px 8px rgba(99,102,241,0.06);
        transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
        display: flex; flex-direction: column;
    }
    .home-card:hover {
        border-color: #a5b4fc; transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(99,102,241,0.12);
    }

    .home-card-top {
        padding: 22px 22px 16px;
        border-bottom: 1px solid #f1f5f9;
        display: flex; align-items: center; gap: 12px;
    }

    .home-card-icon {
        width: 42px; height: 42px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; flex-shrink: 0;
        background: #ede9fe; border: 1px solid #ddd6fe;
    }

    .home-card-name { font-size: 15px; font-weight: 700; color: #1e293b; }
    .home-card-sub  { font-size: 12px; color: #94a3b8; margin-top: 2px; }

    .home-card-body { padding: 16px 22px 20px; flex: 1; display: flex; flex-direction: column; }

    .home-card-desc { font-size: 13px; color: #64748b; line-height: 1.6; flex: 1; margin-bottom: 16px; }

    .home-card-cta {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 13px; font-weight: 700;
        color: #6366f1; text-decoration: none;
        padding: 7px 14px; border-radius: 7px;
        border: 1px solid #ddd6fe; background: #f5f3ff;
        transition: all 0.15s; align-self: flex-start;
    }
    .home-card-cta:hover { background: #ede9fe; border-color: #c4b5fd; color: #6366f1; text-decoration: none; }

    @@media (max-width: 960px) {
        .home-grid { grid-template-columns: 1fr 1fr; }
        .home-hero { flex-direction: column; padding: 32px 28px; }
        .home-hero-right { width: 100%; }
    }
    @@media (max-width: 600px) {
        .home-grid { grid-template-columns: 1fr; }
        .home-hero-title { font-size: 26px; }
    }
</style>

<div class="home-hero">
    <div class="home-hero-left">
        <div class="home-hero-badge">ForoU &mdash; Plataforma Acad&eacute;mica</div>
        <h1 class="home-hero-title">Bienvenido, @userName &#x1F44B;</h1>
        <div class="home-hero-sub">
            Tu espacio para consultas, tareas y colaboraci&oacute;n acad&eacute;mica. Todo en un solo lugar.
        </div>
        <div class="home-hero-actions">
            <a class="home-hero-btn" href="@Url.Action("Index", "Category")">&#x1F4AC; Ir al Foro</a>
            @if (userRole == "Profesor" || userRole == "Estudiante")
            {
                <a class="home-hero-btn-outline" href="@Url.Action("Index", "Assignment")">&#x1F4CB; Mis tareas</a>
            }
        </div>
    </div>

    <div class="home-hero-right">
        <div class="home-hero-avatar">@(userName.Length > 0 ? userName[0].ToString().ToUpper() : "U")</div>
        <div class="home-hero-uname">@userName</div>
        <div class="home-hero-role">@userRole</div>
    </div>
</div>

<div class="home-grid">

    <div class="home-card">
        <div class="home-card-top">
            <div class="home-card-icon">&#x1F4AC;</div>
            <div>
                <div class="home-card-name">Foro</div>
                <div class="home-card-sub">Canales acad&eacute;micos</div>
            </div>
        </div>
        <div class="home-card-body">
            <div class="home-card-desc">
                Acced&eacute; a los canales por materia. Hac&eacute; preguntas, respond&eacute; dudas y particip&aacute; en discusiones acad&eacute;micas.
            </div>
            <a class="home-card-cta" href="@Url.Action("Index", "Category")">Abrir foro &rarr;</a>
        </div>
    </div>

    @if (userRole == "Profesor" || userRole == "Estudiante")
    {
        <div class="home-card">
            <div class="home-card-top">
                <div class="home-card-icon">&#x1F4CB;</div>
                <div>
                    <div class="home-card-name">Tareas</div>
                    <div class="home-card-sub">@(userRole == "Profesor" ? "Gestion de clases" : "Mis entregas")</div>
                </div>
            </div>
            <div class="home-card-body">
                <div class="home-card-desc">
                    @if (userRole == "Profesor")
                    {
                        <text>Cre&aacute; y gestion&aacute; tareas para tus clases. Revis&aacute; las entregas de tus estudiantes.</text>
                    }
                    else
                    {
                        <text>Consult&aacute; las tareas de tus clases y envi&aacute; tus entregas antes de la fecha l&iacute;mite.</text>
                    }
                </div>
                <a class="home-card-cta" href="@Url.Action("Index", "Assignment")">Ver tareas &rarr;</a>
            </div>
        </div>
    }

    <div class="home-card">
        <div class="home-card-top">
            <div class="home-card-icon">&#x1F464;</div>
            <div>
                <div class="home-card-name">Mi perfil</div>
                <div class="home-card-sub">Datos de cuenta</div>
            </div>
        </div>
        <div class="home-card-body">
            <div class="home-card-desc">
                Consult&aacute; tu informaci&oacute;n personal, correo y rol dentro de la plataforma ForoU.
            </div>
            <a class="home-card-cta" href="@Url.Action("Index", "Profiled")">Ver perfil &rarr;</a>
        </div>
    </div>

</div>
