@{
    ViewBag.Title = "Inicio - ForoU";
}

<div class="forou-hero">
    <div class="forou-hero-top">
        <h1 class="forou-hero-title">Bienvenido a ForoU</h1>
        <div class="forou-hero-text">
            Plataforma académica para consultas, colaboración entre estudiantes y
            gestión de tareas universitarias.
        </div>

        <a class="forou-hero-btn" href="@Url.Action("Index", "Category")">Ir a consultas</a>
    </div>

    <div class="forou-card-grid">
        <div class="forou-feature-card">
            <h3>Consultas</h3>
            <p>
                Realizá preguntas académicas, respondé dudas y participá en conversaciones
                por materia dentro de tus categorías.
            </p>
            <a class="forou-feature-link" href="@Url.Action("Index", "Category")">Abrir módulo</a>
        </div>

        <div class="forou-feature-card">
            <h3>Categorías</h3>
            <p>
                Navegá por las materias disponibles y entrá a los hilos de discusión
                según el área académica que necesités.
            </p>
            <a class="forou-feature-link" href="@Url.Action("Index", "Category")">Ver categorías</a>
        </div>

        <div class="forou-feature-card">
            <h3>Mi perfil</h3>
            <p>
                Consultá tu información, correo y asignaturas registradas dentro de
                la plataforma universitaria.
            </p>
            <a class="forou-feature-link" href="@Url.Action("Index", "Profiled")">Ver perfil</a>
        </div>
    </div>
</div>