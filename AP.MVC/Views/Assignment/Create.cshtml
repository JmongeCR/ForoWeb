@model AP.MVC.Models.CreateAssignmentVM

@{
    ViewBag.Title = "Nueva tarea";
}

<style>
    .forou-form-wrap {
        max-width: 860px;
        margin: 0 auto;
    }

    .forou-page-title {
        font-size: 26px;
        font-weight: 800;
        color: #1a3570;
        margin-bottom: 6px;
    }

    .forou-page-subtitle {
        color: #5a6a85;
        margin-bottom: 24px;
        font-size: 15px;
    }

    .forou-form-card {
        background: #fff;
        border: 1px solid #e2e8f4;
        border-radius: 16px;
        padding: 28px;
        box-shadow: 0 2px 8px rgba(26,53,112,0.06);
        margin-bottom: 20px;
    }

    .forou-section-label {
        font-size: 16px;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 18px;
        padding-bottom: 12px;
        border-bottom: 1px solid #e2e8f0;
    }

    .forou-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 18px;
    }

    .forou-label {
        color: #2d3f60;
        font-weight: 700;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .forou-input-dark,
    .forou-textarea-dark,
    .forou-select-dark {
        width: 100%;
        border-radius: 10px;
        border: 1.5px solid #d0d9ee;
        background: #f7f9fd;
        color: #1e2d4a;
        box-sizing: border-box;
        font-size: 14px;
        font-family: inherit;
    }

    .forou-input-dark {
        height: 46px;
        padding: 0 14px;
    }

    .forou-select-dark {
        height: 46px;
        padding: 0 14px;
        appearance: none;
        cursor: pointer;
    }

    .forou-textarea-dark {
        min-height: 120px;
        padding: 12px 14px;
        resize: vertical;
    }

        .forou-input-dark:focus,
        .forou-textarea-dark:focus,
        .forou-select-dark:focus {
            outline: none;
            border-color: #1e4db7;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(30,77,183,0.1);
        }

    .forou-btn-row {
        margin-top: 24px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .forou-btn-submit {
        display: inline-block;
        background: linear-gradient(90deg, #1a3570 0%, #1e4db7 100%);
        color: #fff; border: none;
        padding: 11px 22px; border-radius: 10px;
        font-weight: 700; cursor: pointer; font-size: 14px;
        box-shadow: 0 4px 12px rgba(30,77,183,0.22);
    }
    .forou-btn-submit:hover { opacity: 0.92; }

    .forou-btn-cancel {
        display: inline-block; background: #f0f4ff;
        color: #1e4db7; text-decoration: none;
        padding: 11px 22px; border-radius: 10px;
        font-weight: 700; border: 1.5px solid #bfdbfe; font-size: 14px;
    }
    .forou-btn-cancel:hover { background: #dbeafe; color: #1e3a8a; text-decoration: none; }

    .forou-no-clases {
        color: #64748b; font-size: 14px; padding: 12px 0;
    }

    .field-validation-error {
        color: #991b1b; font-size: 13px; margin-top: 4px;
    }
</style>

<div class="forou-breadcrumb">
    <a href="@Url.Action("Index", "Assignment")">Tareas</a>
    <span class="forou-breadcrumb-sep">›</span>
    <span class="forou-breadcrumb-current">Nueva tarea</span>
</div>

<div class="forou-form-wrap">
    <div class="forou-page-title">Nueva tarea</div>
    <div class="forou-page-subtitle">Complet&aacute; los datos y seleccion&aacute; la clase a la que pertenece la tarea</div>

    @using (Html.BeginForm("Create", "Assignment", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="forou-form-card">
            <div class="forou-section-label">Informaci&oacute;n de la tarea</div>

            <div class="forou-group">
                <label class="forou-label">T&iacute;tulo</label>
                @Html.TextBox("Title", Model.Title, new { @class = "forou-input-dark", placeholder = "", required = "required" })
                @Html.ValidationMessage("Title")
            </div>

            <div class="forou-group">
                <label class="forou-label">Descripci&oacute;n</label>
                @Html.TextArea("Description", Model.Description, new { @class = "forou-textarea-dark", rows = 5, placeholder = "Describi los requisitos y criterios de evaluacion..." })
                @Html.ValidationMessage("Description")
            </div>

            <div class="forou-group">
                <label class="forou-label">Fecha l&iacute;mite de entrega</label>
                @Html.TextBox("DueDate", Model.DueDate.ToString("yyyy-MM-ddTHH:mm"), new { @class = "forou-input-dark", type = "datetime-local" })
                @Html.ValidationMessage("DueDate")
            </div>

            <div class="forou-group">
                <label class="forou-label">Clase</label>
                @if (Model.ProfessorClases != null && Model.ProfessorClases.Count > 0)
                {
                    <select name="ClaseId" class="forou-select-dark">
                        <option value="0">-- Seleccionar clase --</option>
                        @foreach (var cl in Model.ProfessorClases)
                        {
                            <option value="@cl.ClaseId">@cl.Name (@cl.CourseName)</option>
                        }
                    </select>
                }
                else
                {
                    <div class="forou-no-clases">No ten&eacute;s clases asignadas. Pedile al administrador que te asigne una clase.</div>
                }
            </div>
        </div>

        <div class="forou-btn-row">
            <button type="submit" class="forou-btn-submit">Publicar tarea</button>
            <a class="forou-btn-cancel" href="@Url.Action("Index", "Assignment")">Cancelar</a>
        </div>
    }
</div>
