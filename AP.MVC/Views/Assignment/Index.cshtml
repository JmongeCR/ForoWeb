@model IEnumerable<AP.Models.Assignment>

@{
    ViewBag.Title = "Tareas";
    bool isProfesor = ViewBag.IsProfesor == true;
}

<style>
    .forou-page-title {
        font-size: 28px;
        font-weight: 800;
        color: #1a3570;
        margin-bottom: 4px;
    }

    .forou-page-subtitle {
        color: #5a6a85;
        margin-bottom: 20px;
        font-size: 15px;
    }

    .forou-task-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .forou-task-card {
        background: #fff;
        border: 1px solid #e2e8f4;
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 2px 8px rgba(26, 53, 112, 0.05);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        transition: box-shadow 0.15s, transform 0.15s;
    }

    .forou-task-card:hover {
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.1);
        transform: translateY(-1px);
    }

    .forou-task-title {
        font-size: 18px;
        font-weight: 700;
        color: #1a3570;
        margin-bottom: 6px;
    }

    .forou-task-desc {
        color: #4a5e7a;
        font-size: 14px;
        line-height: 1.6;
        margin-bottom: 12px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .forou-task-meta { font-size: 13px; }

    .forou-due-badge {
        display: inline-block;
        background: #ede9fe;
        border: 1px solid #c4b5fd;
        color: #5b21b6;
        padding: 3px 10px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        margin-right: 8px;
    }

    .forou-due-badge.overdue {
        background: #fee2e2;
        border-color: #fecaca;
        color: #991b1b;
    }

    .forou-clase-badge {
        display: inline-block;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
        padding: 3px 10px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
    }

    .forou-task-btn {
        display: inline-block;
        white-space: nowrap;
        background: linear-gradient(90deg, #1a3570 0%, #1e4db7 100%);
        color: #fff;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 13px;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(30, 77, 183, 0.2);
    }

    .forou-task-btn:hover { color: #fff; text-decoration: none; opacity: 0.9; }

    .forou-create-btn {
        display: inline-block;
        background: linear-gradient(90deg, #1a3570 0%, #1e4db7 100%);
        color: #fff;
        text-decoration: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 14px;
        box-shadow: 0 4px 12px rgba(30, 77, 183, 0.2);
    }

    .forou-create-btn:hover { color: #fff; text-decoration: none; opacity: 0.9; }

    .forou-empty-state {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 52px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(99, 102, 241, 0.05);
    }

    @@media (max-width: 700px) {
        .forou-task-card { flex-direction: column; }
    }
</style>

<div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:16px; margin-bottom:24px;">
    <div>
        <div class="forou-page-title">&#x1F4CB; Tareas</div>
        <div class="forou-page-subtitle">
            @(isProfesor ? "Tareas que has publicado para tus clases" : "Tareas asignadas a tus clases")
        </div>
    </div>
    @if (isProfesor)
    {
        <a class="forou-create-btn" href="@Url.Action("Create", "Assignment")">+ Nueva tarea</a>
    }
</div>

@if (!Model.Any())
{
    <div class="forou-empty-state">
        <div style="font-size:44px; margin-bottom:14px;">&#x1F4CB;</div>
        <div style="font-size:18px; font-weight:700; color:#1e293b; margin-bottom:8px;">
            @(isProfesor ? "Todavia no publicaste ninguna tarea" : "No tenes tareas asignadas")
        </div>
        <div style="color:#64748b; font-size:14px;">
            @if (isProfesor)
            {
                <a href="@Url.Action("Create", "Assignment")" style="color:#6366f1; font-weight:600;">Crear la primera tarea &rarr;</a>
            }
            else
            {
                <span>Consult&aacute; con tu profesor si esperabas ver tareas aqu&iacute;.</span>
            }
        </div>
    </div>
}
else
{
    <div class="forou-task-list">
        @foreach (var t in Model)
        {
            bool vencida = t.DueDate < DateTime.Now;
            <div class="forou-task-card">
                <div style="flex:1; min-width:0;">
                    <div class="forou-task-title">@t.Title</div>
                    <div class="forou-task-desc">@t.Description</div>
                    <div class="forou-task-meta">
                        <span class="forou-due-badge @(vencida ? "overdue" : "")">
                            @(vencida ? "Vencida" : "Entrega") &middot; @t.DueDate.ToString("dd/MM/yyyy HH:mm")
                        </span>
                        @if (!string.IsNullOrEmpty(t.ClassName))
                        {
                            <span class="forou-clase-badge">@t.ClassName</span>
                        }
                    </div>
                </div>
                <a class="forou-task-btn" href="@Url.Action("Details", "Assignment", new { id = t.AssignmentId })">
                    Ver tarea &rarr;
                </a>
            </div>
        }
    </div>
}
