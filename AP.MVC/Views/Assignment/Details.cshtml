@model AP.MVC.Models.AssignmentDetailsVM

@{
    ViewBag.Title = Model.Assignment.Title;
    bool isProfesor = Session["UserRole"] != null && Session["UserRole"].ToString() == "Profesor";
    bool vencida = Model.Assignment.DueDate < DateTime.Now;
}

<style>
    .forou-detail-wrap { display: flex; flex-direction: column; gap: 20px; }

    .forou-detail-card {
        background: #fff;
        border: 1px solid #e2e8f4;
        border-radius: 16px;
        padding: 26px;
        box-shadow: 0 2px 8px rgba(26,53,112,0.06);
    }

    .forou-task-title { font-size: 26px; font-weight: 800; color: #1a3570; margin-bottom: 10px; }
    .forou-task-desc { color: #4a5e7a; font-size: 16px; line-height: 1.7; margin-bottom: 16px; white-space: pre-wrap; }
    .forou-meta-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }

    .forou-badge { display: inline-block; padding: 4px 12px; border-radius: 8px; font-size: 13px; font-weight: 700; }
    .forou-badge-due { background: #dbeafe; border: 1px solid #bfdbfe; color: #1e40af; }
    .forou-badge-overdue { background: #fee2e2; border: 1px solid #fecaca; color: #991b1b; }

    .forou-section-title { font-size: 18px; font-weight: 800; color: #1a3570; margin: 0 0 16px 0; }

    .forou-students-list { display: flex; flex-wrap: wrap; gap: 8px; }
    .forou-student-pill {
        background: #f0f6ff; border: 1px solid #bfdbfe;
        border-radius: 999px; padding: 5px 14px;
        color: #1e40af; font-size: 13px; font-weight: 600;
    }

    .forou-submission-list { display: flex; flex-direction: column; gap: 12px; }
    .forou-submission-card {
        background: #f7f9fd; border: 1px solid #e2e8f4;
        border-radius: 12px; padding: 16px;
        display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; flex-wrap: wrap;
    }

    .forou-sub-student { font-weight: 700; color: #1e293b; font-size: 15px; margin-bottom: 4px; }
    .forou-sub-comment { color: #4a5e7a; font-size: 14px; line-height: 1.5; }
    .forou-sub-meta { color: #6b7f9e; font-size: 12px; margin-top: 5px; }

    .forou-download-btn {
        display: inline-flex; align-items: center; gap: 6px;
        background: #dbeafe; border: 1px solid #bfdbfe; color: #1e40af;
        text-decoration: none; padding: 7px 14px; border-radius: 8px;
        font-weight: 700; font-size: 13px; white-space: nowrap;
    }
    .forou-download-btn:hover { background: #bfdbfe; color: #1e3a8a; text-decoration: none; }

    .forou-empty { color: #6b7f9e; font-size: 14px; }

    .forou-group { display: flex; flex-direction: column; margin-bottom: 18px; }
    .forou-label { color: #2d3f60; font-weight: 700; margin-bottom: 7px; font-size: 14px; }

    .forou-textarea-dark {
        width: 100%; min-height: 100px; border-radius: 10px;
        border: 1.5px solid #d0d9ee; background: #f7f9fd;
        color: #1e2d4a; padding: 12px 14px; box-sizing: border-box;
        resize: vertical; font-size: 14px; font-family: inherit;
    }
    .forou-textarea-dark:focus { outline: none; border-color: #1e4db7; background: #fff; box-shadow: 0 0 0 3px rgba(30,77,183,0.1); }

    .forou-file-input { color: #1e2d4a; font-size: 14px; }

    .forou-btn-submit {
        display: inline-block;
        background: linear-gradient(90deg, #1a3570 0%, #1e4db7 100%);
        color: #fff; border: none; padding: 11px 22px;
        border-radius: 10px; font-weight: 700; cursor: pointer; font-size: 14px;
    }
    .forou-btn-submit:hover { opacity: 0.93; }

    .forou-btn-secondary {
        display: inline-block; background: #f0f4ff;
        color: #1e4db7; text-decoration: none;
        padding: 11px 22px; border-radius: 10px;
        font-weight: 700; border: 1.5px solid #bfdbfe; font-size: 14px;
    }
    .forou-btn-secondary:hover { background: #dbeafe; color: #1e3a8a; text-decoration: none; }

    .forou-btn-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px; }

    .forou-success {
        background: #f0fdf4; border: 1px solid #bbf7d0;
        color: #166534; border-radius: 12px; padding: 14px 18px; margin-bottom: 18px;
    }

    .forou-submitted-card {
        background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 18px;
    }
    .forou-submitted-title { font-size: 15px; font-weight: 700; color: #166534; margin-bottom: 10px; }
</style>

<div class="forou-breadcrumb">
    <a href="@Url.Action("Index", "Assignment")">Tareas</a>
    <span class="forou-breadcrumb-sep">&rsaquo;</span>
    <span class="forou-breadcrumb-current">@Model.Assignment.Title</span>
</div>

@if (TempData["Success"] != null)
{
    <div class="forou-success">@TempData["Success"]</div>
}

<div class="forou-detail-wrap">

    <div class="forou-detail-card">
        <div class="forou-task-title">@Model.Assignment.Title</div>
        <div class="forou-task-desc">@Model.Assignment.Description</div>
        <div class="forou-meta-row">
            <span class="forou-badge @(vencida ? "forou-badge-overdue" : "forou-badge-due")">
                @(vencida ? "Vencida" : "Entrega") &middot; @Model.Assignment.DueDate.ToString("dd/MM/yyyy HH:mm")
            </span>
        </div>
    </div>

    @if (isProfesor)
    {
        <div class="forou-detail-card">
            <h2 class="forou-section-title">Estudiantes asignados (@Model.AssignedStudents.Count)</h2>
            @if (Model.AssignedStudents.Count > 0)
            {
                <div class="forou-students-list">
                    @foreach (var s in Model.AssignedStudents)
                    {
                        <span class="forou-student-pill">@s.FullName</span>
                    }
                </div>
            }
            else
            {
                <div class="forou-empty">No hay estudiantes asignados a esta tarea.</div>
            }
        </div>
    }

    @if (isProfesor)
    {
        <div class="forou-detail-card">
            <h2 class="forou-section-title">Entregas recibidas (@(Model.Submissions != null ? Model.Submissions.Count : 0))</h2>

            @if (Model.Submissions != null && Model.Submissions.Count > 0)
            {
                <div class="forou-submission-list">
                    @foreach (var sub in Model.Submissions)
                    {
                        <div class="forou-submission-card">
                            <div style="flex:1; min-width:0;">
                                <div class="forou-sub-student">@sub.StudentName</div>
                                @if (!string.IsNullOrEmpty(sub.Comment))
                                {
                                    <div class="forou-sub-comment">@sub.Comment</div>
                                }
                                <div class="forou-sub-meta">Entregado el @sub.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                            @if (!string.IsNullOrEmpty(sub.FileUrl))
                            {
                                <a class="forou-download-btn" href="@Url.Content(sub.FileUrl)" target="_blank">
                                    Descargar archivo
                                </a>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="forou-empty">Todav&iacute;a no hay entregas para esta tarea.</div>
            }
        </div>
    }
    else
    {
        <div class="forou-detail-card">
            <h2 class="forou-section-title">Mi entrega</h2>

            @if (Model.MySubmission != null)
            {
                <div class="forou-submitted-card">
                    <div class="forou-submitted-title">Entrega registrada el @Model.MySubmission.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</div>
                    @if (!string.IsNullOrEmpty(Model.MySubmission.Comment))
                    {
                        <div style="color:#475569; font-size:15px; margin-bottom:10px;">@Model.MySubmission.Comment</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.MySubmission.FileUrl))
                    {
                        <a class="forou-download-btn" href="@Url.Content(Model.MySubmission.FileUrl)" target="_blank">
                            Ver mi archivo entregado
                        </a>
                    }
                </div>
            }
            else if (vencida)
            {
                <div class="forou-empty">El plazo de entrega ya venci&oacute;.</div>
            }
            else
            {
                using (Html.BeginForm("Submit", "Assignment", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="assignmentId" value="@Model.Assignment.AssignmentId" />

                    <div class="forou-group">
                        <label class="forou-label">Comentario (opcional)</label>
                        <textarea name="comment" class="forou-textarea-dark" placeholder="Pod&eacute;s agregar un comentario sobre tu entrega..."></textarea>
                    </div>

                    <div class="forou-group">
                        <label class="forou-label">Archivo</label>
                        <input type="file" name="file" class="forou-file-input" />
                        <small style="color:#94a3b8; margin-top:6px;">Formatos aceptados: PDF, DOC, DOCX, ZIP, im&aacute;genes</small>
                    </div>

                    <div class="forou-btn-row">
                        <button type="submit" class="forou-btn-submit">Enviar entrega</button>
                        <a class="forou-btn-secondary" href="@Url.Action("Index", "Assignment")">Volver</a>
                    </div>
                }
            }
        </div>
    }

</div>
