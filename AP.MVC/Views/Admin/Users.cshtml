@model IEnumerable<AP.Models.User>

@{
    ViewBag.Title = "Administración de usuarios";
}

<style>
    .forou-admin-wrap {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .forou-admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .forou-admin-title {
        font-size: 34px;
        font-weight: 800;
        color: #ffffff;
        margin: 0 0 6px 0;
    }

    .forou-admin-subtitle {
        color: #c7d0f1;
        font-size: 16px;
        margin: 0;
    }

    .forou-btn-primary {
        display: inline-block;
        background: linear-gradient(90deg, #5f6fff 0%, #7e49ff 100%);
        color: #fff;
        text-decoration: none;
        padding: 12px 18px;
        border-radius: 12px;
        font-weight: 700;
        border: none;
    }

        .forou-btn-primary:hover {
            color: #fff;
            text-decoration: none;
            opacity: 0.95;
        }

    .forou-table-card {
        background: #111328;
        border: 1px solid rgba(123, 137, 255, 0.14);
        border-radius: 20px;
        padding: 18px;
        box-shadow: 0 18px 40px rgba(0,0,0,0.18);
        overflow-x: auto;
    }

    .forou-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 820px;
    }

        .forou-table thead th {
            text-align: left;
            color: #ffffff;
            font-size: 15px;
            font-weight: 800;
            padding: 16px 14px;
            background: rgba(255,255,255,0.04);
            border-bottom: 1px solid rgba(123, 137, 255, 0.14);
        }

        .forou-table tbody td {
            padding: 16px 14px;
            color: #e9edff;
            border-bottom: 1px solid rgba(123, 137, 255, 0.10);
            vertical-align: middle;
        }

        .forou-table tbody tr:hover td {
            background: rgba(255,255,255,0.03);
        }

    .forou-pill {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .forou-pill-role-admin {
        background: rgba(126, 73, 255, 0.16);
        color: #d8c7ff;
        border: 1px solid rgba(126, 73, 255, 0.28);
    }

    .forou-pill-role-student {
        background: rgba(95, 111, 255, 0.16);
        color: #cfd7ff;
        border: 1px solid rgba(95, 111, 255, 0.28);
    }

    .forou-pill-role-professor {
        background: rgba(0, 195, 255, 0.14);
        color: #bfefff;
        border: 1px solid rgba(0, 195, 255, 0.25);
    }

    .forou-pill-active {
        background: rgba(34, 197, 94, 0.14);
        color: #bbf7d0;
        border: 1px solid rgba(34, 197, 94, 0.24);
    }

    .forou-pill-inactive {
        background: rgba(239, 68, 68, 0.14);
        color: #fecaca;
        border: 1px solid rgba(239, 68, 68, 0.24);
    }

    .forou-action-link {
        display: inline-block;
        color: #d8dcff;
        text-decoration: none;
        border: 1px solid rgba(123, 137, 255, 0.26);
        padding: 8px 12px;
        border-radius: 10px;
        font-weight: 700;
    }

        .forou-action-link:hover {
            color: #ffffff;
            text-decoration: none;
            background: rgba(255,255,255,0.05);
        }

    .forou-empty {
        color: #c7d0f1;
        padding: 18px 6px 6px;
    }
</style>

<div class="forou-admin-wrap">
    <div class="forou-admin-header">
        <div>
            <h1 class="forou-admin-title">Administración de usuarios</h1>
            <p class="forou-admin-subtitle">Listado de usuarios registrados en ForoU</p>
        </div>

        <a class="forou-btn-primary" href="@Url.Action("CreateUser", "Admin")">
            Crear usuario
        </a>
    </div>

    <div class="forou-table-card">
        @if (Model != null && Model.Any())
        {
            <table class="forou-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        var roleClass = "forou-pill-role-student";

                        if (u.Role == "Administrador")
                        {
                            roleClass = "forou-pill-role-admin";
                        }
                        else if (u.Role == "Profesor")
                        {
                            roleClass = "forou-pill-role-professor";
                        }

                        <tr>
                            <td>@u.UserId</td>
                            <td>@u.FullName</td>
                            <td>@u.Email</td>
                            <td>
                                <span class="forou-pill @roleClass">@u.Role</span>
                            </td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="forou-pill forou-pill-active">Activo</span>
                                }
                                else
                                {
                                    <span class="forou-pill forou-pill-inactive">Inactivo</span>
                                }
                            </td>
                            <td>
                                <a class="forou-action-link"
                                   href="@Url.Action("EditUser", "Admin", new { id = u.UserId })">
                                    Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="forou-empty">No hay usuarios registrados.</div>
        }
    </div>
</div>