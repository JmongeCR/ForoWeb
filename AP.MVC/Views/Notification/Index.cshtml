@model List<AP.Models.Notification>
@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    ViewBag.Title = "Notificaciones";
}

<div style="max-width:680px; margin:0 auto;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
        <div>
            <div style="font-size:22px; font-weight:800; color:#1e293b;">Notificaciones</div>
            <div style="font-size:13px; color:#64748b; margin-top:2px;">Actividad reciente en tu cuenta</div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center; padding:60px 20px; background:#fff; border:1px solid #e2e8f0; border-radius:12px;">
            <div style="font-size:40px; margin-bottom:12px;">&#x1F514;</div>
            <div style="font-size:15px; font-weight:600; color:#1e293b;">Sin notificaciones</div>
            <div style="font-size:13px; color:#94a3b8; margin-top:6px;">Cuando alguien responda tu hilo o te asignen una tarea apareceran aqui.</div>
        </div>
    }
    else
    {
        <div style="display:flex; flex-direction:column; gap:8px;">
            @foreach (var n in Model)
            {
                <div style="background:#fff; border:1px solid #e2e8f0; border-radius:10px; padding:14px 18px; display:flex; align-items:flex-start; gap:14px; @(!n.IsRead ? "border-left:3px solid #6366f1;" : "")">
                    <div style="width:36px; height:36px; border-radius:50%; background:@(!n.IsRead ? "#ede9fe" : "#f1f5f9"); display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0;">
                        @(!n.IsRead ? Html.Raw("&#x1F514;") : Html.Raw("&#x1F515;"))
                    </div>
                    <div style="flex:1; min-width:0;">
                        <div style="font-size:14px; color:#1e293b; font-weight:@(!n.IsRead ? "600" : "400");">@n.Message</div>
                        <div style="font-size:12px; color:#94a3b8; margin-top:4px;">@n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    @if (!string.IsNullOrEmpty(n.Link))
                    {
                        <a href="@Url.Content(n.Link)" style="flex-shrink:0; font-size:12px; color:#6366f1; text-decoration:none; font-weight:600; padding:4px 10px; border:1px solid #c4b5fd; border-radius:6px; background:#f5f3ff; white-space:nowrap;">Ver</a>
                    }
                </div>
            }
        </div>
    }
</div>
