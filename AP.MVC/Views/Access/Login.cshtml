@{
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
    ViewBag.Title = "Iniciar sesion";
}

<div class="login-form-header">
    <div class="login-form-title">Bienvenido de vuelta</div>
    <div class="login-form-subtitle">Ingres&aacute; con tu cuenta para continuar</div>
</div>

@if (ViewBag.Error != null)
{
    <div class="login-alert">@ViewBag.Error</div>
}

@using (Html.BeginForm("Login", "Access", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <label class="login-label">Correo electr&oacute;nico</label>
    <input type="text" name="email" class="login-input" />

    <label class="login-label">Contrase&ntilde;a</label>
    <input type="password" name="password" class="login-input" />

    <button type="submit" class="login-btn">Iniciar sesi&oacute;n</button>
}
