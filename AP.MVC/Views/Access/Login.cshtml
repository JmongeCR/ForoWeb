@{
    ViewBag.Title = "Login - ForoU";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

<div class="forou-form-title">Iniciar sesión</div>
<div class="forou-form-subtitle">Entrá con tu cuenta para usar el foro.</div>

@if (ViewBag.Error != null)
{
    <div class="forou-alert">@ViewBag.Error</div>
}

@using (Html.BeginForm("Login", "Access", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <label class="forou-form-label">Correo</label>
    <input class="forou-input" type="email" name="email" placeholder="usuario@correo.com" required />

    <label class="forou-form-label">Contraseña</label>
    <input class="forou-input" type="password" name="password" placeholder="••••••••" required />

    <button class="forou-btn-primary" type="submit">Entrar</button>
}

<div style="margin-top:18px; color:#55607a; font-size:14px; line-height:1.6;">
    <strong>Usuarios de prueba:</strong><br />
    Administrador: chrisbeita@ufide.ac.cr / 123456<br />
    Estudiante: estudiante@ForoU.com / 123456<br />
    Profesor: profesor@ForoU.com / 123456
</div>
