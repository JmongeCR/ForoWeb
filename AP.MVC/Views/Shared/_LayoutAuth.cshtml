@{
    var userRole = Session["UserRole"] != null ? Session["UserRole"].ToString() : "";
    var userName = Session["UserName"] != null ? Session["UserName"].ToString() : "Usuario";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title &ndash; ForoU</title>
    @Scripts.Render("~/bundles/modernizr")
    @Styles.Render("~/Content/css")
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; font-family: 'Segoe UI', Arial, sans-serif; background: #f8fafc; color: #1e293b; }

        .fu-topbar {
            background: #6366f1;
            height: 60px;
            display: flex; align-items: center; padding: 0 24px;
            position: sticky; top: 0; z-index: 200;
            box-shadow: 0 2px 8px rgba(99,102,241,0.25);
        }

        .fu-brand {
            display: flex; align-items: center; gap: 10px;
            padding-right: 20px; border-right: 1px solid rgba(255,255,255,0.2);
            margin-right: 18px; text-decoration: none; flex-shrink: 0;
        }
        .fu-brand-logo {
            width: 32px; height: 32px; border-radius: 8px;
            background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3);
            color: #fff; font-weight: 900; font-size: 13px;
            display: flex; align-items: center; justify-content: center;
        }
        .fu-brand-name { color: #fff; font-weight: 800; font-size: 16px; }

        .fu-nav { display: flex; align-items: center; gap: 2px; flex: 1; }

        .fu-nav-link {
            color: rgba(255,255,255,0.7); text-decoration: none;
            padding: 6px 13px; border-radius: 7px;
            font-size: 13px; font-weight: 600; transition: all 0.15s; white-space: nowrap;
        }
        .fu-nav-link:hover { color: #fff; background: rgba(255,255,255,0.12); text-decoration: none; }
        .fu-nav-link.active { color: #fff; background: rgba(255,255,255,0.18); text-decoration: none; }

        .fu-nav-sep { width: 1px; height: 18px; background: rgba(255,255,255,0.2); margin: 0 6px; }
        .fu-nav-section-label { color: rgba(255,255,255,0.4); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 0 6px; }

        .fu-topbar-right { display: flex; align-items: center; gap: 10px; margin-left: auto; flex-shrink: 0; }

        .fu-role-badge {
            display: inline-block; padding: 3px 10px; border-radius: 5px;
            font-size: 11px; font-weight: 700; background: rgba(255,255,255,0.15);
            color: #fff; border: 1px solid rgba(255,255,255,0.25);
        }

        .fu-user-pill {
            display: flex; align-items: center; gap: 8px; text-decoration: none;
            color: #fff; padding: 4px 12px 4px 4px; border-radius: 999px;
            border: 1px solid rgba(255,255,255,0.25); background: rgba(255,255,255,0.1);
            font-size: 13px; font-weight: 600; transition: background 0.15s;
        }
        .fu-user-pill:hover { background: rgba(255,255,255,0.18); color: #fff; text-decoration: none; }

        .fu-user-avatar {
            width: 26px; height: 26px; border-radius: 50%;
            background: rgba(255,255,255,0.25);
            color: #fff; font-weight: 800; font-size: 12px;
            display: flex; align-items: center; justify-content: center;
        }

        .fu-logout-btn {
            display: flex; align-items: center; justify-content: center;
            width: 32px; height: 32px; border-radius: 7px;
            background: transparent; border: 1px solid rgba(255,255,255,0.2);
            color: rgba(255,255,255,0.65); text-decoration: none; font-size: 14px;
            transition: all 0.15s;
        }
        .fu-logout-btn:hover { background: rgba(255,255,255,0.12); color: #fff; text-decoration: none; }

        .fu-bell-btn {
            position: relative; display: flex; align-items: center; justify-content: center;
            width: 34px; height: 34px; border-radius: 7px;
            background: transparent; border: 1px solid rgba(255,255,255,0.2);
            color: rgba(255,255,255,0.8); text-decoration: none; font-size: 16px;
            transition: all 0.15s;
        }
        .fu-bell-btn:hover { background: rgba(255,255,255,0.12); color: #fff; text-decoration: none; }
        .fu-bell-count {
            position: absolute; top: -5px; right: -5px;
            background: #ef4444; color: #fff; font-size: 10px; font-weight: 800;
            min-width: 17px; height: 17px; border-radius: 999px;
            display: flex; align-items: center; justify-content: center; padding: 0 3px;
            border: 1.5px solid #6366f1;
        }

        .fu-content { padding: 28px 36px; min-height: calc(100vh - 60px - 44px); }
        .fu-content-inner { max-width: 1400px; margin: 0 auto; }

        .fu-footer { text-align: center; color: #cbd5e1; font-size: 12px; padding: 12px 0 18px; border-top: 1px solid #f1f5f9; }

        /* Global component overrides */
        .forou-detail-card, .forou-table-card, .forou-form-card, .forou-panel, .forou-submitted-card {
            background: #fff !important; border: 1px solid #e2e8f0 !important;
            border-radius: 12px !important; box-shadow: 0 2px 8px rgba(99,102,241,0.06) !important;
        }

        .forou-task-title, .forou-section-title, .forou-form-title, .forou-admin-title, .forou-page-title { color: #1e293b !important; }
        .forou-task-desc, .forou-sub-comment, .forou-form-subtitle, .forou-empty, .forou-sub-meta, .forou-page-subtitle { color: #64748b !important; }

        .forou-input-dark, .forou-textarea-dark, .forou-select-dark, .forou-input, .forou-textarea, .forou-select {
            background: #f8fafc !important; border: 1.5px solid #e2e8f0 !important; color: #1e293b !important;
        }
        .forou-input-dark:focus, .forou-textarea-dark:focus, .forou-select-dark:focus,
        .forou-input:focus, .forou-textarea:focus, .forou-select:focus {
            border-color: #6366f1 !important; box-shadow: 0 0 0 3px rgba(99,102,241,0.1) !important; background: #fff !important;
        }

        .forou-label { color: #475569 !important; }

        .forou-badge-due { background: #ede9fe !important; border: 1px solid #c4b5fd !important; color: #5b21b6 !important; }
        .forou-badge-overdue { background: #fee2e2 !important; border: 1px solid #fecaca !important; color: #991b1b !important; }
        .forou-badge-course { background: #ede9fe !important; border: 1px solid #c4b5fd !important; color: #5b21b6 !important; }
        .forou-student-pill { background: #f5f3ff !important; border: 1px solid #ddd6fe !important; color: #5b21b6 !important; }

        .forou-submission-card { background: #f8fafc !important; border: 1px solid #e2e8f0 !important; }
        .forou-download-btn { background: #ede9fe !important; border: 1px solid #c4b5fd !important; color: #5b21b6 !important; }
        .forou-download-btn:hover { background: #ddd6fe !important; }

        .forou-submitted-card { background: #f0fdf4 !important; border: 1px solid #bbf7d0 !important; }
        .forou-submitted-title { color: #166534 !important; }
        .forou-success { background: #f0fdf4 !important; border: 1px solid #bbf7d0 !important; color: #166534 !important; }
        .forou-error { background: #fef2f2 !important; border: 1px solid #fecaca !important; color: #dc2626 !important; }

        .forou-btn-submit, .forou-btn-create, .forou-btn-add, .forou-btn-primary,
        .forou-task-btn, .forou-create-btn {
            background: #6366f1 !important; color: #fff !important;
        }
        .forou-btn-secondary, .forou-btn-cancel {
            background: #f5f3ff !important; color: #6366f1 !important; border-color: #ddd6fe !important;
        }
        .forou-btn-secondary:hover, .forou-btn-cancel:hover { background: #ede9fe !important; }

        .forou-category-btn { background: #6366f1 !important; color: #fff !important; }
        .forou-category-btn:hover { opacity: 0.9 !important; color: #fff !important; }

        .forou-table th { background: #f8fafc !important; color: #64748b !important; border-bottom: 1.5px solid #e2e8f0 !important; font-size: 12px !important; text-transform: uppercase !important; letter-spacing: 0.04em !important; }
        .forou-table td { color: #1e293b !important; border-bottom-color: #f8fafc !important; }
        .forou-table tr:hover td { background: #f8fafc !important; }
        .forou-students-table th { color: #64748b !important; border-bottom-color: #e2e8f0 !important; }
        .forou-students-table td { color: #1e293b !important; border-bottom-color: #f8fafc !important; }

        .forou-action-link { color: #6366f1 !important; }
        .forou-action-link:hover { color: #4f46e5 !important; }
        .forou-remove-btn { background: #fee2e2 !important; border-color: #fecaca !important; color: #dc2626 !important; }
        .forou-remove-btn:hover { background: #fecaca !important; }

        .forou-breadcrumb a { color: #94a3b8 !important; }
        .forou-breadcrumb a:hover { color: #6366f1 !important; }
        .forou-breadcrumb-sep { color: #e2e8f0 !important; }
        .forou-breadcrumb-current { color: #475569 !important; }

        .forou-info-item { color: #64748b !important; }
        .forou-info-item strong { color: #1e293b !important; }
        .forou-file-input { color: #1e293b !important; }

        select, option { background: #fff; color: #1e293b; }
    </style>
</head>
<body>
    <header class="fu-topbar">
        <a class="fu-brand" href="@Url.Action("Index", "Home")">
            <div class="fu-brand-logo">FU</div>
            <div class="fu-brand-name">ForoU</div>
        </a>

        <nav class="fu-nav" id="fu-nav">
            <a class="fu-nav-link" data-controller="home" href="@Url.Action("Index", "Home")">Inicio</a>
            <a class="fu-nav-link" data-controller="category" href="@Url.Action("Index", "Category")">Foro</a>
            @if (userRole == "Profesor" || userRole == "Estudiante")
            {
                <a class="fu-nav-link" data-controller="assignment" href="@Url.Action("Index", "Assignment")">Tareas</a>
            }
            <a class="fu-nav-link" data-controller="profiled" href="@Url.Action("Index", "Profiled")">Mi perfil</a>
            <a class="fu-nav-link" data-controller="notification" href="@Url.Action("Index", "Notification")">Notificaciones</a>
            @if (userRole == "Administrador")
            {
                <div class="fu-nav-sep"></div>
                <span class="fu-nav-section-label">Admin</span>
                <a class="fu-nav-link" data-controller="admin" href="@Url.Action("Users", "Admin")">Usuarios</a>
                <a class="fu-nav-link" data-controller="curso" href="@Url.Action("Index", "Curso")">Cursos</a>
                <a class="fu-nav-link" data-controller="clase" href="@Url.Action("Index", "Clase")">Clases</a>
            }
        </nav>

        <div class="fu-topbar-right">
            <span class="fu-role-badge">@userRole</span>
            @Html.Action("BellBadge", "Notification")
            <a class="fu-user-pill" href="@Url.Action("Index", "Profiled")">
                <div class="fu-user-avatar">@(userName.Length > 0 ? userName[0].ToString().ToUpper() : "U")</div>
                <span>@userName</span>
            </a>
            <a class="fu-logout-btn" href="@Url.Action("Logout", "Access")" title="Cerrar sesi&oacute;n">&#x2715;</a>
        </div>
    </header>

    <main class="fu-content">
        <div class="fu-content-inner">
            @RenderBody()
        </div>
    </main>

    <footer class="fu-footer">&copy; 2026 ForoU &middot; Plataforma Acad&eacute;mica</footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
    <script>
        (function () {
            var path = window.location.pathname.toLowerCase();
            document.querySelectorAll('#fu-nav .fu-nav-link[data-controller]').forEach(function (link) {
                var ctrl = '/' + link.getAttribute('data-controller').toLowerCase();
                if (ctrl === '/home' && (path === '/' || path.indexOf('/home') === 0)) link.classList.add('active');
                else if (ctrl !== '/home' && path.indexOf(ctrl) === 0) link.classList.add('active');
            });
        })();
    </script>
</body>
</html>
