@model AP.MVC.Models.ThreadDetailsVM

@{
    ViewBag.Title = Model.Thread != null ? Model.Thread.Title : "Detalle";
}

<style>
    .forou-detail-wrap { display: flex; flex-direction: column; gap: 20px; }

    .forou-thread-title { font-size: 24px; font-weight: 800; color: #1e293b; margin-bottom: 10px; }
    .forou-thread-message { color: #475569; font-size: 16px; line-height: 1.7; margin-bottom: 12px; }
    .forou-thread-meta { color: #94a3b8; font-size: 13px; }

    .forou-replies-list { display: flex; flex-direction: column; gap: 12px; }

    .forou-reply-card {
        background: #f8fafc; border: 1px solid #e2e8f0;
        border-radius: 12px; padding: 16px;
    }

    .forou-reply-message { color: #1e293b; font-size: 15px; line-height: 1.6; margin-bottom: 8px; }
    .forou-reply-meta { color: #94a3b8; font-size: 13px; }

    .forou-form-label { display: block; color: #475569; font-weight: 700; margin-bottom: 8px; font-size: 14px; }

    .forou-btn-row { display: flex; gap: 10px; flex-wrap: wrap; }
</style>

<div class="forou-breadcrumb">
    <a href="@Url.Action("Index", "Category")">Foro</a>
    <span class="forou-breadcrumb-sep">&rsaquo;</span>
    <a href="@Url.Action("Index", "Thread", new { categoryId = Model.Thread.CategoryId })">Consultas</a>
    <span class="forou-breadcrumb-sep">&rsaquo;</span>
    <span class="forou-breadcrumb-current">@Model.Thread.Title</span>
</div>

<div class="forou-detail-wrap">

    <div class="forou-detail-card">
        <div class="forou-thread-title">@Model.Thread.Title</div>
        <div class="forou-thread-message">@Model.Thread.Message</div>
        <div class="forou-thread-meta">@Model.Thread.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
    </div>

    <div class="forou-detail-card">
        <h2 class="forou-section-title">Respuestas</h2>

        @if (Model.Replies != null && Model.Replies.Count > 0)
        {
            <div class="forou-replies-list">
                @foreach (var r in Model.Replies)
                {
                    <div class="forou-reply-card">
                        <div class="forou-reply-message">@r.Message</div>
                        <div class="forou-reply-meta">
                            <strong style="color:#475569;">@r.AuthorName</strong>
                            &middot; @r.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="forou-empty">S&eacute; el primero en responder esta consulta.</div>
        }
    </div>

    <div class="forou-detail-card">
        <h2 class="forou-section-title">Responder</h2>

        @using (Html.BeginForm("Create", "Reply", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="ThreadId" value="@Model.Thread.ThreadId" />

            <label class="forou-form-label">Escrib&iacute; tu respuesta</label>
            <textarea name="Message" class="forou-textarea" style="width:100%; min-height:120px; margin-bottom:14px;" required></textarea>

            <div class="forou-btn-row">
                <button type="submit" class="forou-btn-primary">Publicar respuesta</button>
                <a class="forou-btn-secondary" href="@Url.Action("Index", "Thread", new { categoryId = Model.Thread.CategoryId })">Volver a consultas</a>
            </div>
        }
    </div>

</div>
