@model AP.Models.Thread
@{
    ViewBag.Title = "Crear Thread";
}

<div class="page-title">Crear nueva consulta</div>
<div class="page-sub">Publicá una duda o conversación en esta categoría</div>

<div class="forum-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.CategoryId)

        <div class="form-group mb-3">
            <label class="form-label-dark">Título</label>
            @Html.TextBoxFor(m => m.Title, new { @class = "form-control forum-input" })
        </div>

        <div class="form-group mb-3">
            <label class="form-label-dark">Mensaje</label>
            @Html.TextAreaFor(m => m.Message, new { @class = "form-control forum-input", rows = 6 })
        </div>

        <button type="submit" class="btn btn-primary">Crear</button>

        @Html.ActionLink(
            "Cancelar",
            "Index",
            "Thread",
            new { categoryId = Model.CategoryId },
            new { @class = "btn btn-outline-light ms-2" }
        )
    }
</div>