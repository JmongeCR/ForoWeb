@model AP.Models.Thread

@{
    ViewBag.Title = "Crear consulta";
}

<style>
    .forou-form-wrap { max-width: 860px; margin: 0 auto; }
    .forou-page-title { font-size: 26px; font-weight: 800; color: #1a3570; margin-bottom: 6px; }
    .forou-page-subtitle { color: #5a6a85; margin-bottom: 24px; font-size: 15px; }

    .forou-form-card {
        background: #fff; border: 1px solid #e2e8f4;
        border-radius: 16px; padding: 28px;
        box-shadow: 0 2px 10px rgba(26,53,112,0.07);
    }

    .forou-group { display: flex; flex-direction: column; margin-bottom: 18px; }
    .forou-label { color: #2d3f60; font-weight: 700; margin-bottom: 8px; font-size: 14px; }

    .forou-input-dark, .forou-textarea-dark {
        width: 100%; border-radius: 10px;
        border: 1.5px solid #d0d9ee;
        background: #f7f9fd; color: #1e2d4a;
        box-sizing: border-box; font-size: 15px; font-family: inherit;
    }
    .forou-input-dark { height: 46px; padding: 0 14px; }
    .forou-textarea-dark { min-height: 140px; padding: 12px 14px; resize: vertical; }
    .forou-input-dark:focus, .forou-textarea-dark:focus {
        outline: none; border-color: #1e4db7; background: #fff;
        box-shadow: 0 0 0 3px rgba(30,77,183,0.1);
    }

    .forou-btn-row { margin-top: 22px; display: flex; gap: 10px; flex-wrap: wrap; }

    .forou-btn-submit {
        display: inline-block;
        background: linear-gradient(90deg, #1a3570 0%, #1e4db7 100%);
        color: #fff; border: none; padding: 11px 22px;
        border-radius: 10px; font-weight: 700; cursor: pointer;
        font-size: 15px; font-family: inherit;
        box-shadow: 0 4px 12px rgba(30,77,183,0.2);
    }
    .forou-btn-submit:hover { opacity: 0.9; }

    .forou-btn-cancel {
        display: inline-block; background: #f0f4fa;
        color: #1e4db7; text-decoration: none;
        padding: 11px 22px; border-radius: 10px;
        font-weight: 700; border: 1px solid #d0d9ee; font-size: 15px;
    }
    .forou-btn-cancel:hover { background: #dbeafe; color: #1a3570; text-decoration: none; }

    .field-validation-error { color: #9b1535; font-size: 13px; margin-top: 4px; }
</style>

<div class="forou-breadcrumb">
    <a href="@Url.Action("Index", "Category")">Categor&iacute;as</a>
    <span class="forou-breadcrumb-sep">&rsaquo;</span>
    <a href="@Url.Action("Index", "Thread", new { categoryId = Model.CategoryId })">Consultas</a>
    <span class="forou-breadcrumb-sep">&rsaquo;</span>
    <span class="forou-breadcrumb-current">Nueva consulta</span>
</div>

<div class="forou-form-wrap">
    <div class="forou-page-title">Nueva consulta</div>
    <div class="forou-page-subtitle">Public&aacute; tu duda o conversaci&oacute;n en esta categor&iacute;a</div>

    <div class="forou-form-card">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.CategoryId)

            <div class="forou-group">
                <label class="forou-label">T&iacute;tulo</label>
                @Html.TextBoxFor(m => m.Title, new { @class = "forou-input-dark", placeholder = "Escrib\u00ed un t\u00edtulo claro y descriptivo", required = "required" })
                @Html.ValidationMessageFor(m => m.Title)
            </div>

            <div class="forou-group">
                <label class="forou-label">Mensaje</label>
                @Html.TextAreaFor(m => m.Message, new { @class = "forou-textarea-dark", rows = 7, placeholder = "Describ\u00ed tu consulta con el mayor detalle posible..." })
                @Html.ValidationMessageFor(m => m.Message)
            </div>

            <div class="forou-btn-row">
                <button type="submit" class="forou-btn-submit">Publicar consulta</button>
                @Html.ActionLink("Cancelar", "Index", "Thread", new { categoryId = Model.CategoryId }, new { @class = "forou-btn-cancel" })
            </div>
        }
    </div>
</div>
