@model IEnumerable<AP.Models.Thread>

@{
    ViewBag.Title = "Consultas";
    var categoryId = ViewBag.CategoryId != null ? (int)ViewBag.CategoryId : 0;
    var categoryName = ViewBag.CategoryName != null ? ViewBag.CategoryName.ToString() : "Canal";
}

<style>
    .canal-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 24px;
    }

    .canal-back {
        display: inline-flex; align-items: center; gap: 6px;
        color: #94a3b8; font-size: 13px; font-weight: 600;
        text-decoration: none; margin-bottom: 10px;
        transition: color 0.15s;
    }
    .canal-back:hover { color: #6366f1; text-decoration: none; }

    .canal-name {
        font-size: 26px; font-weight: 800; color: #1e293b; margin-bottom: 4px;
    }

    .canal-sub { color: #64748b; font-size: 15px; }

    .canal-new-btn {
        display: inline-flex; align-items: center; gap: 8px;
        background: #6366f1; color: #fff; text-decoration: none;
        padding: 11px 20px; border-radius: 10px;
        font-weight: 700; font-size: 14px;
        box-shadow: 0 4px 14px rgba(99,102,241,0.25);
        transition: opacity 0.15s;
        white-space: nowrap; flex-shrink: 0;
    }
    .canal-new-btn:hover { color: #fff; text-decoration: none; opacity: 0.9; }

    .canal-list { display: flex; flex-direction: column; gap: 12px; }

    .canal-thread {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 20px 22px;
        display: flex;
        align-items: flex-start;
        gap: 16px;
        box-shadow: 0 2px 6px rgba(99,102,241,0.05);
        transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
    }

    .canal-thread:hover {
        box-shadow: 0 6px 20px rgba(99,102,241,0.1);
        border-color: #a5b4fc;
        transform: translateY(-1px);
    }

    .canal-thread-icon {
        width: 42px; height: 42px; border-radius: 10px;
        background: #ede9fe; border: 1px solid #ddd6fe;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; flex-shrink: 0;
    }

    .canal-thread-body { flex: 1; min-width: 0; }

    .canal-thread-title {
        font-size: 16px; font-weight: 700; color: #1e293b;
        margin-bottom: 5px;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    .canal-thread-preview {
        color: #64748b; font-size: 14px; line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
        margin-bottom: 8px;
    }

    .canal-thread-meta { color: #94a3b8; font-size: 12px; }

    .canal-closed-badge {
        display: inline-flex; align-items: center; gap: 4px;
        background: #fef2f2; border: 1px solid #fecaca;
        color: #dc2626; font-size: 11px; font-weight: 700;
        padding: 2px 8px; border-radius: 999px;
        margin-left: 8px;
    }

    .canal-thread-action {
        display: inline-flex; align-items: center; gap: 5px;
        background: #f5f3ff; color: #6366f1; border: 1px solid #ddd6fe;
        text-decoration: none;
        padding: 8px 15px; border-radius: 8px;
        font-weight: 700; font-size: 13px;
        flex-shrink: 0; white-space: nowrap;
        transition: all 0.15s;
    }
    .canal-thread-action:hover { background: #ede9fe; border-color: #c4b5fd; color: #6366f1; text-decoration: none; }

    .canal-empty {
        background: #fff; border: 1px solid #e2e8f0;
        border-radius: 16px; padding: 56px 40px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(99,102,241,0.04);
    }

    @@media (max-width: 640px) {
        .canal-thread { flex-wrap: wrap; }
        .canal-thread-action { width: 100%; justify-content: center; }
    }
</style>

<div class="canal-header">
    <div>
        <a class="canal-back" href="@Url.Action("Index", "Category")">&#8592; Volver al Foro</a>
        <div class="canal-name">@categoryName</div>
        <div class="canal-sub">Consultas abiertas en este canal</div>
    </div>
    <a class="canal-new-btn" href="@Url.Action("Create", "Thread", new { categoryId = categoryId })">
        + Nueva consulta
    </a>
</div>

@if (!Model.Any())
{
    <div class="canal-empty">
        <div style="font-size:44px; margin-bottom:14px;">&#x1F4AC;</div>
        <div style="font-size:18px; font-weight:800; color:#1e293b; margin-bottom:8px;">Todav&iacute;a no hay consultas</div>
        <div style="color:#64748b;">S&eacute; el primero en abrir una conversaci&oacute;n en este canal.</div>
    </div>
}
else
{
    <div class="canal-list">
        @foreach (var t in Model)
        {
            <div class="canal-thread">
                <div class="canal-thread-icon">&#x1F4AC;</div>
                <div class="canal-thread-body">
                    <div class="canal-thread-title">
                        @t.Title
                        @if (t.IsClosed)
                        {
                            <span class="canal-closed-badge">&#x1F512; Cerrado</span>
                        }
                    </div>
                    <div class="canal-thread-preview">@t.Message</div>
                    <div class="canal-thread-meta">@t.CreatedAt.ToString("dd/MM/yyyy") &middot; @t.CreatedAt.ToString("HH:mm")</div>
                </div>
                <a class="canal-thread-action"
                   href="@Url.Action("Details", "Thread", new { id = t.ThreadId })">
                    Ver &rarr;
                </a>
            </div>
        }
    </div>
}
